# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=huevos_point
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=8h

# Server
PORT=3001
NODE_ENV=development

# Email SMTP (para resumen diario automático)
# Con Gmail: activar "Contraseñas de aplicación" en la cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_NAME=Huevos Point
SMTP_FROM_EMAIL=tu_cuenta@gmail.com

# Cron secret (generar un token aleatorio seguro, ej: openssl rand -hex 32)
CRON_SECRET=reemplazar_con_token_seguro

# Mobbex (suscripciones con tarjeta)
MOBBEX_API_KEY=xxxxx
MOBBEX_ACCESS_TOKEN=xxxxx

# MercadoPago (suscripciones PreApproval)
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_WEBHOOK_SECRET=xxxxx

# URLs de la plataforma
APP_LOGIN_URL=https://app.huevospoint.com/login
LANDING_URL=https://huevospoint.com

# Email de contacto interno (recibe consultas del plan personalizado)
CONTACT_EMAIL=leandrodelosantos@gmail.com
