{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-summary",
      "schedule": "30 23 * * 1-5"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "30 17 * * 6"
    }
  ]
}
